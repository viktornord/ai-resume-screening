# Set to true for offline dev without Mistral API calls
MOCK_LLM=false

# Mistral API (https://console.mistral.ai/) — loaded from this file at repo root
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
LOG_LEVEL=INFO
# json | pretty | auto — auto uses pretty when LOG_LEVEL=DEBUG
LOG_FORMAT=auto
